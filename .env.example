# Supabase credentials — copy this file to .env.local and fill in from your Supabase dashboard
# (Project Settings -> API). Without these, the login/signup pages show a setup message.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Comma-separated emails that always have admin access (bootstrap list).
ADMIN_EMAILS=you@example.com

# Primary owner — cannot be demoted from the admin panel (defaults to first ADMIN_EMAIL).
OWNER_EMAIL=you@example.com

# Server-only — NEVER prefix with NEXT_PUBLIC_. Used by API routes for spins, purchases, leaderboard.
# Find in Supabase Dashboard -> Project Settings -> API -> service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# HMAC signing secret for math CAPTCHA on /api/spin (any long random string, e.g. openssl rand -hex 32)
CAPTCHA_SIGNING_SECRET=

# Discord vouch channel (optional) — powers the Customer Reviews stat from your #vouches channel.
# Create a bot at https://discord.com/developers/applications, enable Message Content Intent,
# invite it to your server with Read Message History on the vouch channel.
DISCORD_BOT_TOKEN=
DISCORD_VOUCH_CHANNEL_ID=

# Stripe (optional) — enables real Visa/Mastercard charges at checkout.
# Get these from https://dashboard.stripe.com/apikeys after creating a Stripe account.
# Leave blank to keep card payments manual (FIB transfer + WhatsApp confirmation).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Presentment currency for Stripe Checkout (e.g. usd, iqd). Defaults to usd.
STRIPE_CURRENCY=usd

# Google AdSense (optional) — when set, AdSlot renders real ad units instead of dummy banners.
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT=xxxxxxxx

# ---------------------------------------------------------------------------
# Netlify deployment (auto-build on push to main)
# ---------------------------------------------------------------------------
# 1. Push repo to GitHub; connect repo in Netlify (branch: main).
# 2. Add ALL env vars below in Netlify -> Site settings -> Environment variables.
# 3. Apply supabase/migrations/*.sql in Supabase SQL Editor.
# 4. Never commit .env.local — only this .env.example goes in git.
#
# Optional — distributed rate limiting (recommended in production):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Orders flow — Discord + email notifications
# DISCORD_ORDERS_CHANNEL_ID=
# DISCORD_INVITE_URL=https://discord.gg/your-invite
# ADMIN_ORDER_EMAIL=you@example.com
# RESEND_API_KEY=
# ORDER_EMAIL_FROM=orders@yourdomain.com
